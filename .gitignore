# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# r2-import pipeline staging (multi-GB temp files)
/scripts/r2-import/_workspace
/scripts/r2-import/node_modules

# QR generator outputs (regenerable, can be large)
/qr-output

.vercel

# supabase CLI cache (project ref + linked metadata stay local)
supabase/.temp/

# IDE workspace files
*.code-workspace
